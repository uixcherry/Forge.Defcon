<Window x:Class="Forge.Defcon.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Forge.Defcon.Converters"
        xmlns:vm="clr-namespace:Forge.Defcon.ViewModels"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Forge Defcon" Width="1150" Height="740"
        Icon="Assets/icon.ico"
        MinWidth="950" MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="CanResizeWithGrip">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:LogLevelToBrushConverter x:Key="LevelBrush"/>
        <conv:SeverityToBrushConverter x:Key="SevBrush"/>
        <conv:ModuleStateToBrushConverter x:Key="ModBrush"/>
        <conv:TabToVisibilityConverter x:Key="TabVis"/>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <sys:Int32 x:Key="Tab0">0</sys:Int32>
        <sys:Int32 x:Key="Tab1">1</sys:Int32>
    </Window.Resources>

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8"
            Background="{StaticResource BgBrush}" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="26"/>
            </Grid.RowDefinitions>

            <!-- ═══ TITLE BAR ═══ -->
            <Border Grid.Row="0" Background="{StaticResource TitleBarGradient}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                        <Border Background="{StaticResource AccentBrush}" CornerRadius="3" Width="4" Height="14" Margin="0,0,10,0" VerticalAlignment="Center" Opacity="0.9"/>
                        <TextBlock Text="FORGE" Foreground="{StaticResource TextBrush}" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text="DEFCON" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        <TextBlock Text="v1.0" Foreground="{StaticResource TextDimBrush}" FontSize="9" VerticalAlignment="Center" Margin="10,2,0,0"/>
                    </StackPanel>

                    <!-- Tab Switcher -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Command="{Binding SwitchTabCommand}" CommandParameter="{StaticResource Tab0}" Cursor="Hand" Margin="1,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="tb" Background="Transparent" CornerRadius="5" Padding="16,5">
                                        <TextBlock x:Name="tt" Text="SCAN" FontSize="10.5" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextDimBrush}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="tb" Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsScanTab}" Value="True">
                                            <Setter TargetName="tt" Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                            <Setter TargetName="tb" Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Command="{Binding SwitchTabCommand}" CommandParameter="{StaticResource Tab1}" Cursor="Hand" Margin="1,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="tb" Background="Transparent" CornerRadius="5" Padding="16,5">
                                        <TextBlock x:Name="tt" Text="TOOLS" FontSize="10.5" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextDimBrush}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="tb" Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsToolsTab}" Value="True">
                                            <Setter TargetName="tt" Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                            <Setter TargetName="tb" Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="─" Click="Minimize_Click" Width="40" Height="36" FontSize="11" Foreground="{StaticResource TextSecBrush}" Style="{StaticResource GhostBtn}" Padding="0"/>
                        <Button Content="□" Click="Maximize_Click" Width="40" Height="36" FontSize="11" Foreground="{StaticResource TextSecBrush}" Style="{StaticResource GhostBtn}" Padding="0"/>
                        <Button Content="✕" Click="Close_Click" Width="40" Height="36" FontSize="11" Foreground="{StaticResource TextSecBrush}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#C42B1C"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ MAIN CONTENT ═══ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ═══ SIDEBAR ═══ -->
                <Border Grid.Column="0" Background="{StaticResource SidebarGradient}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                    <DockPanel>
                        <Border DockPanel.Dock="Bottom" Padding="12,8"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                            <TextBlock Text="Forge Defcon v1.0" Foreground="{StaticResource TextDimBrush}"
                                       FontSize="10" FontFamily="{StaticResource MonoFont}"/>
                        </Border>

                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="6,10,6,8">
                                <TextBlock Text="MODULES" FontSize="9.5" FontWeight="Bold"
                                           Foreground="{StaticResource TextDimBrush}" Margin="10,0,0,6"/>

                                <!-- Show All -->
                                <Button Command="{Binding ShowAllThreatsCommand}" Cursor="Hand" Margin="0,0,0,2">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="row" CornerRadius="5" Padding="10,6" Background="Transparent">
                                                <DockPanel>
                                                    <TextBlock Text="◈" FontSize="10" Width="16" Foreground="{StaticResource AccentBrush}"
                                                               VerticalAlignment="Center" FontFamily="{StaticResource MonoFont}"/>
                                                    <TextBlock Text="All Modules" FontSize="11.5" Foreground="{StaticResource AccentBrush}"
                                                               FontWeight="SemiBold" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                                </DockPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="row" Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- Module List -->
                                <ItemsControl ItemsSource="{Binding ModuleStatuses}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border x:Name="moduleRow" CornerRadius="3" Margin="0,0,0,1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <DockPanel>
                                                    <Button DockPanel.Dock="Right" Cursor="Hand" ToolTip="Run this module"
                                                            Command="{Binding DataContext.RunSingleModuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding Index}">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="pb" Background="Transparent" Padding="6,5" CornerRadius="3">
                                                                    <TextBlock Text="▶" FontSize="8" Foreground="{StaticResource TextDimBrush}"
                                                                               VerticalAlignment="Center" x:Name="icon"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="icon" Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                                        <Setter TargetName="pb" Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>

                                                    <Button Cursor="Hand"
                                                            Command="{Binding DataContext.SelectModuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding Index}">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="btn" Background="Transparent" Padding="8,5" CornerRadius="3">
                                                                    <DockPanel>
                                                                        <TextBlock Text="{Binding StateSymbol}" FontSize="10" Width="16"
                                                                                   Foreground="{Binding State, Converter={StaticResource ModBrush}}"
                                                                                   VerticalAlignment="Center" FontFamily="{StaticResource MonoFont}"/>
                                                                        <TextBlock Text="{Binding Name}" FontSize="11"
                                                                                   Foreground="{StaticResource TextSecBrush}"
                                                                                   VerticalAlignment="Center" Margin="5,0,0,0"
                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                        <TextBlock FontSize="10" HorizontalAlignment="Right"
                                                                                   Foreground="{Binding State, Converter={StaticResource ModBrush}}"
                                                                                   VerticalAlignment="Center" FontWeight="SemiBold" Margin="4,0,0,0">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Text" Value="{Binding ThreatCount}"/>
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding ThreatCount}" Value="0">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </DockPanel>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="btn" Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- STATISTICS -->
                                <TextBlock Text="STATISTICS" FontSize="9.5" FontWeight="Bold"
                                           Foreground="{StaticResource TextDimBrush}" Margin="10,14,0,6"/>

                                <Border Background="{StaticResource SurfaceLightBrush}" CornerRadius="6" Padding="12,10" Margin="2,0"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,4">
                                            <TextBlock Text="Total" Foreground="{StaticResource TextSecBrush}" FontSize="11"/>
                                            <TextBlock Text="{Binding ThreatCount}" HorizontalAlignment="Right" Foreground="{StaticResource TextBrush}" FontSize="11" FontWeight="Bold"/>
                                        </DockPanel>
                                        <DockPanel Margin="0,0,0,4">
                                            <TextBlock Text="Critical" Foreground="{StaticResource RedBrush}" FontSize="11"/>
                                            <TextBlock Text="{Binding CriticalCount}" HorizontalAlignment="Right" Foreground="{StaticResource RedBrush}" FontSize="11" FontWeight="Bold"/>
                                        </DockPanel>
                                        <DockPanel Margin="0,0,0,4">
                                            <TextBlock Text="High" Foreground="{StaticResource OrangeBrush}" FontSize="11"/>
                                            <TextBlock Text="{Binding HighCount}" HorizontalAlignment="Right" Foreground="{StaticResource OrangeBrush}" FontSize="11" FontWeight="Bold"/>
                                        </DockPanel>
                                        <DockPanel Margin="0,0,0,4">
                                            <TextBlock Text="Medium/Low" Foreground="{StaticResource YellowBrush}" FontSize="11"/>
                                            <TextBlock Text="{Binding MediumCount}" HorizontalAlignment="Right" Foreground="{StaticResource YellowBrush}" FontSize="11" FontWeight="Bold"/>
                                        </DockPanel>
                                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,4,0,0" Margin="0,2,0,0">
                                            <DockPanel>
                                                <TextBlock Text="Duration" Foreground="{StaticResource TextSecBrush}" FontSize="11"/>
                                                <TextBlock Text="{Binding LastScanTime}" HorizontalAlignment="Right"
                                                           Foreground="{StaticResource AccentBrush}" FontSize="11" FontFamily="{StaticResource MonoFont}"/>
                                            </DockPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- ═══ RIGHT PANEL ═══ -->
                <Grid Grid.Column="1">

                    <!-- ════ TAB 0: SCAN ════ -->
                    <Grid Visibility="{Binding ActiveTab, Converter={StaticResource TabVis}, ConverterParameter=0}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="220" MinHeight="100"/>
                        </Grid.RowDefinitions>

                        <!-- SCAN HEADER + PROGRESS -->
                        <Border Grid.Row="0" Padding="24,18,24,16"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                                Background="{StaticResource TitleBarGradient}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <!-- Row 0: Title + Status + Buttons -->
                                <Grid Margin="0,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="SYSTEM SCAN" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                        <Border Background="{StaticResource SurfaceLightBrush}" CornerRadius="5" Padding="12,4" Margin="14,0,0,0" VerticalAlignment="Center"
                                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                            <TextBlock Text="{Binding StatusText}" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource AccentBrush}" FontFamily="{StaticResource MonoFont}"/>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Background="{StaticResource SurfaceLightBrush}" CornerRadius="5" Padding="12,6" Margin="0,0,10,0"
                                                Visibility="{Binding IsScanning, Converter={StaticResource BoolVis}}">
                                            <TextBlock Text="{Binding ElapsedText}" FontSize="12" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource TextSecBrush}"/>
                                        </Border>
                                        <Button Style="{StaticResource DangerBtn}" Content="STOP" Command="{Binding StopScanCommand}"
                                                Visibility="{Binding IsScanning, Converter={StaticResource BoolVis}}" Margin="0,0,10,0" Padding="18,9" FontSize="11"/>
                                        <Button Style="{StaticResource PrimaryBtn}" Content="{Binding ScanButtonText}"
                                                Command="{Binding StartScanCommand}" Padding="24,10" FontSize="12"/>
                                    </StackPanel>
                                </Grid>
                                <!-- Row 1: Progress bar (full width) -->
                                <Grid Grid.Row="1" x:Name="ProgressRow" Margin="0,14,0,0" Visibility="{Binding IsScanning, Converter={StaticResource BoolVis}}"
                                      Opacity="0">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsScanning}" Value="True">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <Setter Property="Opacity" Value="1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ProgressBar Grid.Column="0" Value="{Binding Progress}" Minimum="0" Maximum="100"
                                                 Style="{StaticResource ScanProgress}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Progress, StringFormat={}{0}%}"
                                               FontSize="11" FontFamily="{StaticResource MonoFont}"
                                               Foreground="{StaticResource TextSecBrush}"
                                               VerticalAlignment="Center" Margin="12,0,0,0" FontWeight="SemiBold"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- THREATS LIST with expandable items -->
                        <Border Grid.Row="1" Margin="16,10,16,4">
                            <DockPanel>
                                <DockPanel DockPanel.Dock="Top" Margin="4,0,4,6">
                                    <TextBlock Text="DETECTED THREATS" FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center"/>
                                    <Border Background="{StaticResource SurfaceLightBrush}" CornerRadius="4"
                                            Padding="8,2" Margin="8,0,0,0" VerticalAlignment="Center"
                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                        <TextBlock Text="{Binding FilteredThreats.Count}" FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBrush}"/>
                                    </Border>
                                    <Border Background="{StaticResource SurfaceLightBrush}" CornerRadius="4"
                                            Padding="8,2" Margin="6,0,0,0" VerticalAlignment="Center"
                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Filter: " FontSize="9.5" Foreground="{StaticResource TextDimBrush}"/>
                                            <TextBlock Text="{Binding FilterLabel}" FontSize="9.5" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextSecBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </DockPanel>

                                <ListBox ItemsSource="{Binding FilteredThreats}"
                                         Background="{StaticResource SurfaceBrush}"
                                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                         Padding="4"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.CanContentScroll="True"
                                         VirtualizingStackPanel.IsVirtualizing="True"
                                         VirtualizingStackPanel.VirtualizationMode="Recycling">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <ContentPresenter/>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource SurfaceLightBrush}" CornerRadius="6" Margin="3" Padding="0"
                                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                                <StackPanel>
                                                    <!-- Clickable header row -->
                                                    <ToggleButton x:Name="expandToggle" Cursor="Hand">
                                                        <ToggleButton.Template>
                                                            <ControlTemplate TargetType="ToggleButton">
                                                                <Border x:Name="hdr" Background="Transparent" Padding="12,10" CornerRadius="6">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="3"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <Border Grid.Column="0" CornerRadius="1.5"
                                                                                Background="{Binding Severity, Converter={StaticResource SevBrush}}"
                                                                                Margin="0,2,8,2"/>
                                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                            <DockPanel>
                                                                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextBrush}"
                                                                                           FontWeight="SemiBold" FontSize="12"/>
                                                                                <TextBlock Text="{Binding CategoryLabel}" Foreground="{StaticResource TextDimBrush}"
                                                                                           FontSize="9.5" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                                            </DockPanel>
                                                                            <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextSecBrush}"
                                                                                       FontSize="10.5" Margin="0,2,0,0" TextWrapping="NoWrap"
                                                                                       TextTrimming="CharacterEllipsis"/>
                                                                        </StackPanel>
                                                                        <Border Grid.Column="2" CornerRadius="3" Padding="7,2"
                                                                                VerticalAlignment="Center" Margin="8,0,0,0"
                                                                                Background="{Binding Severity, Converter={StaticResource SevBrush}}" Opacity="0.85">
                                                                            <TextBlock Text="{Binding SeverityLabel}" Foreground="#0B0E11"
                                                                                       FontSize="9" FontWeight="Bold" FontFamily="{StaticResource MonoFont}"/>
                                                                        </Border>
                                                                        <TextBlock Grid.Column="3" x:Name="arrow" Text="▾" FontSize="10"
                                                                                   Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center"
                                                                                   Margin="8,0,4,0"/>
                                                                    </Grid>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="hdr" Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsChecked" Value="True">
                                                                        <Setter TargetName="arrow" Property="Text" Value="▴"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </ToggleButton.Template>
                                                    </ToggleButton>

                                                    <!-- Expandable details -->
                                                    <Border x:Name="detailsPanel" Visibility="Collapsed" Opacity="0"
                                                            Background="#0A0E12" Padding="18,12,18,14" Margin="14,0,14,10"
                                                            CornerRadius="6" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                                        <StackPanel>
                                                            <DockPanel Margin="0,0,0,4">
                                                                <TextBlock Text="Module" Foreground="{StaticResource TextDimBrush}" FontSize="10" Width="70"/>
                                                                <TextBlock Text="{Binding ModuleName}" Foreground="{StaticResource AccentBrush}" FontSize="10.5" FontWeight="SemiBold"/>
                                                            </DockPanel>
                                                            <DockPanel Margin="0,0,0,4">
                                                                <TextBlock Text="Severity" Foreground="{StaticResource TextDimBrush}" FontSize="10" Width="70"/>
                                                                <TextBlock Text="{Binding SeverityLabel}" FontSize="10.5" FontWeight="SemiBold"
                                                                           Foreground="{Binding Severity, Converter={StaticResource SevBrush}}"/>
                                                            </DockPanel>
                                                            <DockPanel Margin="0,0,0,4">
                                                                <TextBlock Text="Category" Foreground="{StaticResource TextDimBrush}" FontSize="10" Width="70"/>
                                                                <TextBlock Text="{Binding CategoryLabel}" Foreground="{StaticResource TextSecBrush}" FontSize="10.5"/>
                                                            </DockPanel>
                                                            <DockPanel Margin="0,0,0,4">
                                                                <TextBlock Text="Time" Foreground="{StaticResource TextDimBrush}" FontSize="10" Width="70"/>
                                                                <TextBlock Text="{Binding DetectedAt, StringFormat=HH:mm:ss}" Foreground="{StaticResource TextSecBrush}"
                                                                           FontSize="10.5" FontFamily="{StaticResource MonoFont}"/>
                                                            </DockPanel>
                                                            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                                                                    Padding="0,6,0,0" Margin="0,4,0,0">
                                                                <StackPanel>
                                                                    <TextBlock Text="DESCRIPTION" Foreground="{StaticResource TextDimBrush}" FontSize="9" FontWeight="Bold" Margin="0,0,0,4"/>
                                                                    <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextBrush}"
                                                                               FontSize="11" TextWrapping="Wrap"/>
                                                                </StackPanel>
                                                            </Border>
                                                            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                                                                    Padding="0,6,0,0" Margin="0,6,0,0"
                                                                    Visibility="{Binding HasDetails, Converter={StaticResource BoolVis}}">
                                                                <StackPanel>
                                                                    <TextBlock Text="DETAILS" Foreground="{StaticResource TextDimBrush}" FontSize="9" FontWeight="Bold" Margin="0,0,0,4"/>
                                                                    <TextBlock Text="{Binding Details}" Foreground="{StaticResource TextSecBrush}"
                                                                               FontSize="10.5" TextWrapping="Wrap" FontFamily="{StaticResource MonoFont}"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                                <Border.Triggers>
                                                    <EventTrigger SourceName="expandToggle" RoutedEvent="ToggleButton.Checked">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="detailsPanel" Storyboard.TargetProperty="Visibility">
                                                                    <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}"/>
                                                                </ObjectAnimationUsingKeyFrames>
                                                                <DoubleAnimation Storyboard.TargetName="detailsPanel" Storyboard.TargetProperty="Opacity"
                                                                                 From="0" To="1" Duration="0:0:0.2"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                    <EventTrigger SourceName="expandToggle" RoutedEvent="ToggleButton.Unchecked">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="detailsPanel" Storyboard.TargetProperty="Visibility">
                                                                    <DiscreteObjectKeyFrame KeyTime="0:0:0.15" Value="{x:Static Visibility.Collapsed}"/>
                                                                </ObjectAnimationUsingKeyFrames>
                                                                <DoubleAnimation Storyboard.TargetName="detailsPanel" Storyboard.TargetProperty="Opacity"
                                                                                 From="1" To="0" Duration="0:0:0.15"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Border.Triggers>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </Border>

                        <!-- SPLITTER -->
                        <GridSplitter Grid.Row="2" Height="4" HorizontalAlignment="Stretch" Background="Transparent" Cursor="SizeNS"/>

                        <!-- CONSOLE -->
                        <Border Grid.Row="3" Background="{StaticResource ConsoleBgBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                            <DockPanel>
                                <Border DockPanel.Dock="Top" Padding="12,5"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <DockPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="▸" Foreground="{StaticResource AccentBrush}" FontSize="10" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="CONSOLE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Content="Copy" Command="{Binding CopyLogsCommand}"
                                                    Style="{StaticResource GhostBtn}" FontSize="10" Margin="0,0,4,0"/>
                                            <Button Content="Clear" Command="{Binding ClearConsoleCommand}"
                                                    Style="{StaticResource GhostBtn}" FontSize="10"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>

                                <ListBox x:Name="ConsoleListBox" ItemsSource="{Binding LogEntries}"
                                         Background="Transparent" BorderThickness="0" Padding="4,2"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.CanContentScroll="True"
                                         VirtualizingStackPanel.IsVirtualizing="True"
                                         VirtualizingStackPanel.VirtualizationMode="Recycling">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Focusable" Value="False"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <ContentPresenter/>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="6,0.5">
                                                <TextBlock Text="{Binding FormattedTime}" Width="78"
                                                           Foreground="{StaticResource TextDimBrush}"
                                                           FontFamily="{StaticResource MonoFont}" FontSize="11"/>
                                                <TextBlock Text="{Binding Prefix}" Width="46" FontWeight="SemiBold"
                                                           Foreground="{Binding Level, Converter={StaticResource LevelBrush}}"
                                                           FontFamily="{StaticResource MonoFont}" FontSize="11"/>
                                                <TextBlock Text="{Binding Message}" TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{Binding Level, Converter={StaticResource LevelBrush}}"
                                                           FontFamily="{StaticResource MonoFont}" FontSize="11"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </Border>
                    </Grid>

                    <!-- ════ TAB 1: TOOLS ════ -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding ActiveTab, Converter={StaticResource TabVis}, ConverterParameter=1}">
                        <StackPanel Margin="24,20">

                            <!-- ACTIONS -->
                            <TextBlock Text="ACTIONS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,10"/>
                            <WrapPanel>
                                <Button Style="{StaticResource ToolBtn}" Margin="0,0,8,8"
                                        Command="{Binding ExportReportCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📄" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <StackPanel>
                                            <TextBlock Text="Export Report" FontSize="12" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                            <TextBlock Text="Save full report to file" FontSize="10" Foreground="{StaticResource TextDimBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ToolBtn}" Margin="0,0,8,8"
                                        Command="{Binding CopyThreatsCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📋" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <StackPanel>
                                            <TextBlock Text="Copy Threats" FontSize="12" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                            <TextBlock Text="Copy all threats to clipboard" FontSize="10" Foreground="{StaticResource TextDimBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ToolBtn}" Margin="0,0,8,8"
                                        Command="{Binding CopyLogsCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📝" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <StackPanel>
                                            <TextBlock Text="Copy Logs" FontSize="12" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                            <TextBlock Text="Copy console logs to clipboard" FontSize="10" Foreground="{StaticResource TextDimBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ToolBtn}" Margin="0,0,8,8"
                                        Click="Screenshot_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📷" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <StackPanel>
                                            <TextBlock Text="Screenshot" FontSize="12" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                            <TextBlock Text="Save app screenshot to file" FontSize="10" Foreground="{StaticResource TextDimBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Button>
                            </WrapPanel>

                            <!-- SYSTEM INFO -->
                            <TextBlock Text="SYSTEM INFORMATION" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextDimBrush}" Margin="0,20,0,10"/>
                            <Border Background="{StaticResource SurfaceLightBrush}" CornerRadius="8"
                                    Padding="20,16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <TextBlock Text="{Binding SystemInfo}" Foreground="{StaticResource TextSecBrush}"
                                           FontSize="12" FontFamily="{StaticResource MonoFont}"
                                           LineHeight="22" TextWrapping="Wrap"/>
                            </Border>

                            <!-- QUICK GUIDE -->
                            <TextBlock Text="QUICK GUIDE" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextDimBrush}" Margin="0,20,0,10"/>
                            <Border Background="{StaticResource SurfaceLightBrush}" CornerRadius="8"
                                    Padding="20,16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Foreground="{StaticResource TextSecBrush}" FontSize="11.5" TextWrapping="Wrap" LineHeight="20"
                                               Text="1. Press START SCAN to run all modules or click ▶ on a module to run it individually."/>
                                    <TextBlock Foreground="{StaticResource TextSecBrush}" FontSize="11.5" TextWrapping="Wrap" LineHeight="20" Margin="0,4,0,0"
                                               Text="2. Click any detected threat to expand its details."/>
                                    <TextBlock Foreground="{StaticResource TextSecBrush}" FontSize="11.5" TextWrapping="Wrap" LineHeight="20" Margin="0,4,0,0"
                                               Text="3. Click a module name in the sidebar to filter threats by that module."/>
                                    <TextBlock Foreground="{StaticResource TextSecBrush}" FontSize="11.5" TextWrapping="Wrap" LineHeight="20" Margin="0,4,0,0"
                                               Text="4. Use Export Report to save a full report or Copy Threats for quick sharing."/>
                                    <TextBlock Foreground="{StaticResource TextSecBrush}" FontSize="11.5" TextWrapping="Wrap" LineHeight="20" Margin="0,4,0,0"
                                               Text="5. Take a Screenshot to capture the current app view."/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- ═══ STATUS BAR ═══ -->
            <Border Grid.Row="2" Background="{StaticResource TitleBarGradient}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="14,0">
                <DockPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" Margin="0,0,6,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource GreenBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsScanning}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding StatusBarText}" FontSize="10.5" Foreground="{StaticResource TextSecBrush}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding ElapsedText}" FontSize="10" Foreground="{StaticResource TextDimBrush}"
                                   FontFamily="{StaticResource MonoFont}" Margin="0,0,12,0"/>
                        <TextBlock Text="Modules: " FontSize="10" Foreground="{StaticResource TextDimBrush}"/>
                        <TextBlock Text="{Binding ModuleStatuses.Count}" FontSize="10" Foreground="{StaticResource TextSecBrush}" FontWeight="SemiBold"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
